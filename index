.page-banner{padding:3rem 2rem 2rem;background:rgba(0,0,0,.35);border-bottom:1px solid var(--border-lt)}
.page-banner-inner{max-width:1100px;margin:0 auto;display:flex;align-items:flex-end;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.page-banner-title{font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#fff;line-height:1;margin-bottom:.5rem}

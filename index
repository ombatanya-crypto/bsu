function submitListing() {
  const title = document.getElementById('upTitle')?.value.trim();
  const loc = document.getElementById('upLoc')?.value.trim();
  const price = parseInt(document.getElementById('upPrice')?.value);
  if(!title || !loc || !price) { toast('Please fill in all required fields', 'error'); return; }
  const imageUrl = state.uploadDraftImage || document.getElementById('upImageUrl')?.value.trim() || 'https://images.unsplash.com/photo-1484154218962-a197022b5858?w=700&h=420&fit=crop';
  const bucket = getCurrentStudentListings();
  bucket.push({ id:Date.now(), type:document.getElementById('upType').value, title, location:loc, price, beds:parseInt(document.getElementById('upBeds').value), baths:1, sqft:700, availability:'Available', tags:['New Listing'], desc:document.getElementById('upDesc').value||'Recently listed property near BSU.', amenities:['Contact for details'], img:imageUrl, agent:state.user.name, distance:'Contact for distance' });
  state.uploadDraftImage = '';
  closeModal();
  toast('Listing added successfully! 🏠', 'success');
  buildHousingCards();
}


function updateUploadPreviewFromUrl(url) {
  const preview = document.getElementById('upPreview');
  if(!preview) return;
  if(!url.trim()) {
    state.uploadDraftImage = '';
    preview.innerHTML = 'Image preview will appear here';
    return;
  }
  state.uploadDraftImage = url.trim();
  preview.innerHTML = `<img src="${url.trim()}" alt="Listing preview" style="width:100%;height:100%;object-fit:cover" onerror="this.parentElement.innerHTML='Could not load image URL preview'"/>`;
}

function updateUploadPreviewFromFile(event) {
  const file = event.target.files && event.target.files[0];
  const preview = document.getElementById('upPreview');
  if(!preview || !file) return;
  const reader = new FileReader();
  reader.onload = () => {
    state.uploadDraftImage = reader.result;
    preview.innerHTML = `<img src="${reader.result}" alt="Uploaded preview" style="width:100%;height:100%;object-fit:cover"/>`;
  };
  reader.readAsDataURL(file);
}


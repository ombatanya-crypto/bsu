async function sendAIMessage() {
  const input = document.getElementById('aiInput');
  if(!input || !input.value.trim() || state.isBotTyping) return;
  const text = input.value.trim();
  input.value = '';
  state.isBotTyping = true;
  const sendBtn = document.getElementById('aiSendBtn');
  if(sendBtn) sendBtn.disabled = true;
  state.chatbotMessages.push({role:'user', content:text});
  const chipsEl = document.getElementById('aiChips');
  if(chipsEl) chipsEl.style.display='none';
  renderAIMessages(true);

  // Only keep user/assistant turns for the API call
  const apiMessages = state.chatbotMessages
    .filter(m => m.role === 'user' || m.role === 'assistant')
    .map(m => ({role: m.role, content: m.content}));

  // Build headers — add API key when provided (needed outside Claude.ai)
  const headers = { 'Content-Type': 'application/json' };
  if(state.userApiKey) {
    headers['x-api-key'] = state.userApiKey;
    headers['anthropic-version'] = '2023-06-01';
    headers['anthropic-dangerous-direct-browser-access'] = 'true';
  }

  try {
    if(!state.userApiKey) throw new Error('No API key configured');
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers,
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',  // correct model string for Claude.ai artifacts
        max_tokens: 1000,
        system: BOT_SYSTEM,
        messages: apiMessages
      })
    });

    if(!res.ok) {
      const errData = await res.json().catch(()=>({}));
      throw new Error(errData?.error?.message || `HTTP ${res.status}`);
    }

    const data = await res.json();
    const fullResponse = (data.content || [])
      .map(item => item.type === 'text' ? item.text : '')
      .filter(Boolean)
      .join('\n');

    if(fullResponse) {
      state.chatbotMessages.push({role:'assistant', content: fullResponse});
    } else {
      throw new Error('Empty response');
    }

  } catch(err) {
    console.error('Maya chat error:', err.message);
    // If API failed and no key is set, prompt the user to add one
    if(!state.userApiKey) {
      const notice = document.getElementById('aiKeyNotice');
      if(notice) notice.classList.add('show');
    }
    // Always give a helpful BSU-specific answer as fallback
    const fallback = getBSUFallback(text);
    state.chatbotMessages.push({role:'assistant', content: fallback});
  }

  state.isBotTyping = false;
  if(sendBtn) sendBtn.disabled = false;
  renderAIMessages(false);
}


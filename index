function toast(msg, type='info') {
  const t = document.getElementById('toast');
  const icons = { success:'✓', error:'✕', info:'ℹ' };
  t.innerHTML = `<span>${icons[type]||'ℹ'}</span> ${msg}`;
  t.className = `toast show ${type}`;
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(() => t.className = 'toast', 3200);
}

function goTo(page, opts) {
  state.page = page;
  if(opts) Object.assign(state, opts);
  render();
  window.scrollTo({top:0,behavior:'smooth'});
}

function showModal(html) {
  document.getElementById('modalContent').innerHTML = html;
  document.getElementById('modalOverlay').classList.add('show');
}

function closeModal(e) {
  if(!e || e.target === document.getElementById('modalOverlay')) {
    document.getElementById('modalOverlay').classList.remove('show');
  }
}

function goToLifecycle() {
  if(state.page !== 'home') {
    goTo('home');
    setTimeout(() => { const el = document.getElementById('lifecycleSection'); if(el) el.scrollIntoView({behavior:'smooth', block:'start'}); }, 90);
    return;
  }
  const section = document.getElementById('lifecycleSection');
  if(section) section.scrollIntoView({ behavior:'smooth', block:'start' });
}


function openLifecycleStage(stage) {
  const routes = {
    prearrival: { page:'resources', msg:'Start with immigration and pre-arrival resources.' },
    arrival: { page:'resources', msg:'Use campus arrival resources and onboarding guides.' },
    housing: { page:'housing', msg:'Browse and upload housing listings for your class.' },
    academics: { page:'mentorship', msg:'Connect with mentors for academic planning support.' },
    career: { page:'chatbot', msg:'Ask Maya about CPT, OPT, and career planning.' },
    graduation: { page:'chatbot', msg:'Ask Maya about graduation and next-step planning.' }
  };
  const target = routes[stage] || { page:'home', msg:'Lifecycle stage selected.' };
  toast(target.msg, 'info');
  goTo(target.page);
}

function selectDemoStudent(email) {
  if(!email) { logout(); return; }
  const demo = DEMO_STUDENTS.find(student => student.email === email);
  if(!demo) return;
  state.user = { name: demo.name, email: demo.email, initials: demo.initials };
  state.currentStudentEmail = demo.email;
  ensureStudentBucket(demo.name);
  state.chatbotMessages = [];
  toast(`Switched to ${demo.name}`, 'success');
  toggleMob(true);
  render();
}



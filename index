<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BSU International Student Portal — Bowie State University</title>
<meta name="description" content="Bowie State University's official international student support portal. Find housing, connect with mentors, access resources, and get AI-powered guidance."/>
<meta name="theme-color" content="#0b2545"/>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎓</text></svg>"/>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;0,800;1,400;1,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>

:root {
  --orange:      #f58220;
  --orange-dk:   #d86f16;
  --orange-lt:   #fff3e0;
  --orange-glow: rgba(245,130,32,0.22);
  --navy:        #0048B5;
  --navy2:       #003a92;
  --navy3:       #002f76;
  --navy-glass:  rgba(0,72,181,0.85);
  --white:       #ffffff;
  --off-white:   #f8f7f4;
  --light:       #f1f0ed;
  --gray:        #7a7a8a;
  --gray2:       #4a4a5a;
  --border:      rgba(0,0,0,0.08);
  --border-lt:   rgba(255,255,255,0.1);
  --shadow-sm:   0 2px 12px rgba(0,0,0,0.07);
  --shadow-md:   0 8px 32px rgba(0,0,0,0.12);
  --shadow-lg:   0 20px 60px rgba(0,0,0,0.18);
  --shadow-xl:   0 32px 80px rgba(0,0,0,0.25);
  --ease:        cubic-bezier(0.16,1,0.3,1);
  --ease2:       cubic-bezier(0.4,0,0.2,1);
  --font:        'Manrope',sans-serif;
  --serif:       'Playfair Display',serif;
  --mono:        'JetBrains Mono',monospace;
  --r-sm: 8px; --r-md: 14px; --r-lg: 20px; --r-xl: 28px;
}


*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:var(--font);background:var(--off-white);color:var(--navy);line-height:1.65;overflow-x:hidden}
::selection{background:var(--orange);color:#fff}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%;object-fit:cover}
button{font-family:inherit;cursor:pointer;border:none;outline:none}
input,textarea,select{font-family:inherit;outline:none}
ul{list-style:none}
.hidden{display:none!important}


::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--light)}
::-webkit-scrollbar-thumb{background:var(--navy2);border-radius:10px}
::-webkit-scrollbar-thumb:hover{background:var(--orange)}


@keyframes rise{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scaleIn{from{opacity:0;transform:scale(.97)}to{opacity:1;transform:scale(1)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes blink{0%,80%,100%{opacity:.2}40%{opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}


#toast{position:fixed;bottom:2rem;right:2rem;z-index:9999;background:var(--navy);color:#fff;padding:12px 20px;border-radius:var(--r-md);font-size:.85rem;font-weight:500;box-shadow:var(--shadow-lg);transform:translateY(20px);opacity:0;transition:all .35s var(--ease);pointer-events:none;max-width:320px;display:flex;align-items:center;gap:8px}
#toast.show{transform:translateY(0);opacity:1}
#toast.success{border-left:4px solid #38a169}
#toast.error{border-left:4px solid #e53e3e}
#toast.info{border-left:4px solid var(--orange)}


.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;z-index:800;padding:1.5rem;opacity:0;pointer-events:none;transition:opacity .3s}
.modal-overlay.show{opacity:1;pointer-events:all}
.modal{background:#fff;border-radius:var(--r-xl);padding:2.25rem;max-width:560px;width:100%;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow-xl);transform:scale(.96) translateY(16px);transition:transform .38s var(--ease)}
.modal-overlay.show .modal{transform:scale(1) translateY(0)}
.modal::-webkit-scrollbar{width:4px}
.modal-close-btn{float:right;background:var(--light);border:1px solid var(--border);width:32px;height:32px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:var(--gray);cursor:pointer;font-size:.85rem;transition:background .2s,color .2s;margin-left:.5rem}
.modal-close-btn:hover{background:var(--orange);color:#fff}
.modal h2{font-family:var(--serif);font-size:1.4rem;font-weight:700;margin-bottom:1.25rem;color:var(--navy)}


.btn{display:inline-flex;align-items:center;gap:6px;cursor:pointer;border:none;border-radius:999px;font-family:var(--font);font-weight:600;transition:all .22s var(--ease2);text-decoration:none}
.btn-primary{background:var(--orange);color:#fff;padding:11px 24px;font-size:.875rem;box-shadow:0 4px 16px var(--orange-glow)}
.btn-primary:hover{background:var(--orange-dk);transform:translateY(-2px);box-shadow:0 8px 24px var(--orange-glow)}
.btn-outline{background:transparent;color:var(--navy);border:1.5px solid var(--navy);padding:10px 22px;font-size:.875rem}
.btn-outline:hover{background:var(--navy);color:#fff}
.btn-outline-white{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.6);padding:10px 22px;font-size:.875rem}
.btn-outline-white:hover{background:rgba(255,255,255,.12)}
.btn-ghost{background:var(--light);color:var(--navy);border:1px solid var(--border);padding:9px 20px;font-size:.85rem}
.btn-ghost:hover{background:var(--navy);color:#fff}
.btn-sm{padding:7px 16px;font-size:.78rem}
.btn-lg{padding:14px 32px;font-size:.95rem}
.btn-full{width:100%;justify-content:center;border-radius:var(--r-md)}


#navbar{position:sticky;top:0;z-index:600;height:62px;padding:0 2.5rem;display:flex;align-items:center;justify-content:space-between;background:rgba(11,37,69,.96);backdrop-filter:blur(20px) saturate(180%);border-bottom:1px solid rgba(255,255,255,.08);transition:all .3s}
.nav-brand{display:flex;align-items:center;gap:10px;cursor:pointer}
.nav-brand-badge{background:var(--orange);color:#fff;font-weight:800;font-size:.78rem;letter-spacing:.06em;padding:.28rem .75rem;border-radius:7px}
.nav-brand-name{color:#fff;font-size:.95rem;font-weight:600;opacity:.85}
.nav-links{display:flex;align-items:center;gap:.25rem}
.nav-link{display:flex;align-items:center;gap:5px;padding:.42rem 1rem;border-radius:var(--r-sm);color:rgba(255,255,255,.65);font-size:.8rem;font-weight:500;cursor:pointer;transition:color .2s,background .2s;border:none;background:transparent;font-family:var(--font)}
.nav-link i{font-size:.78rem}
.nav-link:hover{color:#fff;background:rgba(255,255,255,.08)}
.nav-link.active{color:var(--orange);background:rgba(245,130,32,.12)}
.nav-right{display:flex;align-items:center;gap:.75rem}
.user-badge{display:flex;align-items:center;gap:8px;padding:.35rem .9rem .35rem .5rem;background:var(--orange);border-radius:999px;cursor:pointer;transition:opacity .2s}
.user-badge:hover{opacity:.88}
.user-avatar{width:26px;height:26px;border-radius:50%;background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800}
.user-badge span{color:#fff;font-size:.8rem;font-weight:600}
.hamburger{display:none;background:none;border:none;color:#fff;font-size:1.3rem;cursor:pointer}
/* Sidebar menu component - animated overlay & drawer */
#sidebar-menu{
  --orange:#f58220;
  --navy:#0b2545;
  --navy-glass:rgba(11,37,69,0.9);
}
.menu-overlay{position:fixed;inset:0;background:rgba(7,12,22,.58);z-index:700;opacity:0;pointer-events:none;transition:opacity 0.35s ease;backdrop-filter:blur(2px)}
.menu-overlay.open{opacity:1;pointer-events:auto}
.menu-drawer{position:fixed;top:0;left:0;width:min(84vw,360px);height:100vh;background:linear-gradient(180deg,var(--navy-glass) 0%,rgba(8,25,48,.98) 100%);border-right:1px solid rgba(255,255,255,.08);box-shadow:0 24px 56px rgba(0,0,0,.45);transform:translateX(-105%);transition:transform 0.35s cubic-bezier(0.2, 0.9, 0.3, 1);display:flex;flex-direction:column;z-index:701}
.menu-overlay.open .menu-drawer{transform:translateX(0)}
.menu-head{display:flex;justify-content:space-between;align-items:center;padding:1rem 1rem .7rem 1rem}
.menu-title-wrap{display:flex;align-items:center;gap:.65rem}
.bc-badge{width:38px;height:38px;border-radius:999px;background:var(--orange);display:grid;place-items:center;font-weight:800;color:#111;font-size:1.05rem;box-shadow:0 0 0 2px rgba(245,130,32,.2)}
.menu-title{font-size:1.35rem;font-weight:700;color:#fff}
.menu-close{width:34px;height:34px;border-radius:999px;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.08);color:#fff;font-size:1.35rem;line-height:1;display:grid;place-items:center;cursor:pointer}
.menu-close:hover{background:rgba(255,255,255,.16)}
.menu-links{padding:.45rem .7rem 1rem;display:flex;flex-direction:column;gap:.25rem;overflow:auto}
.menu-item{display:flex;align-items:center;gap:.95rem;padding:.8rem .9rem;border-radius:12px;color:#fff;font-weight:600;font-size:1.05rem;transition:background .2s,color .2s,border-color .2s;border:1px solid transparent;cursor:pointer}
.menu-item i,.menu-item .emoji{width:25px;font-size:1.1rem;text-align:center;color:var(--orange)}
.menu-item.active,.menu-item:hover{background:rgba(255,255,255,.12);border-color:rgba(245,130,32,.3)}
.menu-sep{height:1px;background:rgba(255,255,255,.14);margin:.45rem .9rem .1rem}
.menu-item.logout{color:#ff5a5a}
.menu-item.logout i,.menu-item.logout .emoji{color:#ff4747}

/* On larger screens the drawer is always visible, but we keep animation for toggle */
@media (min-width:1024px){
  .menu-overlay{background:transparent;opacity:1;pointer-events:none;top:62px;height:calc(100vh - 62px);width:300px}
  .menu-drawer{transform:translateX(0);height:calc(100vh - 62px);top:62px;width:300px;pointer-events:auto}
  .menu-close{display:none}
}

.light-page{min-height:100vh;background:var(--off-white)}
.dark-page{min-height:100vh;background:linear-gradient(160deg,var(--navy) 0%,var(--navy2) 60%,var(--navy3) 100%);color:#fff}
.dark-topbar{height:56px;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,.3);border-bottom:1px solid var(--border-lt);backdrop-filter:blur(12px)}
.dark-brand{display:flex;align-items:center;gap:10px}
.dark-brand-badge{width:34px;height:34px;background:var(--orange);border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.82rem;color:#fff}
.dark-brand-text{font-weight:700;font-size:.9rem}
.dark-brand-sub{font-size:.68rem;opacity:.5}
.dark-topbar-right{display:flex;align-items:center;gap:.75rem}


.hero{position:relative;min-height:92vh;display:flex;align-items:center;overflow:hidden}
.hero-bg{position:absolute;inset:0}
.hero-bg img{width:100%;height:100%;object-fit:cover}
.hero-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(105deg,rgba(11,37,69,.92) 0%,rgba(11,37,69,.7) 55%,rgba(11,37,69,.4) 100%)}
.hero-inner{position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:6rem 2.5rem 5rem;display:grid;grid-template-columns:1fr 430px;gap:5rem;align-items:center}
.hero-eyebrow{display:inline-flex;align-items:center;gap:.65rem;background:rgba(245,130,32,.18);border:1px solid rgba(245,130,32,.35);border-radius:999px;padding:.32rem .9rem;font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--orange);margin-bottom:1.5rem;animation:rise .7s .1s var(--ease) both}
.hero-h1{font-family:var(--serif);font-size:clamp(2.8rem,5.5vw,5rem);font-weight:800;line-height:.98;letter-spacing:-.02em;color:#fff;margin-bottom:1.5rem;animation:rise .8s .22s var(--ease) both}
.hero-h1 em{color:var(--orange);font-style:italic;font-weight:400}
.hero-p{font-size:1.02rem;color:rgba(255,255,255,.72);line-height:1.78;max-width:480px;font-weight:300;margin-bottom:2.25rem;animation:rise .8s .36s var(--ease) both}
.hero-btns{display:flex;gap:.9rem;flex-wrap:wrap;margin-bottom:3rem;animation:rise .8s .48s var(--ease) both}
.hero-stats{display:flex;gap:2rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,.12);animation:rise .8s .6s var(--ease) both}
.h-stat-num{font-family:var(--serif);font-size:2rem;font-weight:700;color:var(--orange);line-height:1}
.h-stat-label{font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-top:.25rem}
/* Hero right card */
.hero-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:var(--r-xl);padding:2rem;backdrop-filter:blur(16px);animation:rise .9s .3s var(--ease) both;position:relative;overflow:hidden}
.hero-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(245,130,32,.18),transparent 70%)}
.hero-card-title{font-size:.82rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:1.2rem}
.hero-listing-row{display:flex;align-items:center;gap:.85rem;padding:.75rem;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:var(--r-md);margin-bottom:.7rem;cursor:pointer;transition:background .2s}
.hero-listing-row:hover{background:rgba(255,255,255,.1)}
.hero-listing-thumb{width:48px;height:48px;border-radius:8px;overflow:hidden;flex-shrink:0}
.hero-listing-thumb img{width:100%;height:100%}
.hero-listing-info{flex:1;min-width:0}
.hero-listing-name{font-size:.83rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#fff}
.hero-listing-loc{font-size:.72rem;color:rgba(255,255,255,.45);margin-top:.15rem}
.hero-listing-price{font-size:.82rem;font-weight:700;color:var(--orange);white-space:nowrap}
.hero-ai-teaser{background:rgba(245,130,32,.1);border:1px solid rgba(245,130,32,.25);border-radius:var(--r-md);padding:.9rem 1rem;margin-top:1.2rem}
.hero-ai-teaser-msg{font-size:.78rem;color:rgba(255,255,255,.7);line-height:1.55;margin-bottom:.5rem}
.hero-ai-teaser-msg strong{color:#fff}
.hero-ai-fake-input{display:flex;align-items:center;gap:.5rem;background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:.42rem .8rem}
.hero-ai-fake-input span{font-size:.74rem;color:rgba(255,255,255,.3);flex:1}
.hero-ai-fake-input i{color:var(--orange);font-size:.8rem}
.hero-mentor-row{display:flex;align-items:center;gap:-.4rem;margin-top:.75rem}
.hero-mentor-avatar{width:34px;height:34px;border-radius:50%;background:var(--orange);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;border:2px solid rgba(255,255,255,.2);margin-left:-.3rem;first-child:margin-left:0;transition:transform .2s;cursor:pointer}
.hero-mentor-avatar:hover{transform:scale(1.15)}
.hero-mentor-more{font-size:.72rem;color:rgba(255,255,255,.5);margin-left:.6rem}


.home-section{padding:5rem 2.5rem}
.home-section-inner{max-width:1200px;margin:0 auto}
.section-overline{font-size:.72rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--orange);margin-bottom:.75rem}
.section-title{font-family:var(--serif);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:700;line-height:1.1;letter-spacing:-.02em;margin-bottom:.9rem;color:var(--navy)}
.section-sub{font-size:.95rem;color:var(--gray);max-width:520px;font-weight:300;line-height:1.75}
.section-head{margin-bottom:3rem}
/* Feature cards */
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.feature-card{background:#fff;border:1px solid var(--border);border-radius:var(--r-lg);padding:2rem;position:relative;overflow:hidden;transition:transform .25s,box-shadow .25s;cursor:pointer}
.feature-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg)}
.feature-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--orange);transform:scaleX(0);transform-origin:left;transition:transform .3s var(--ease)}
.feature-card:hover::before{transform:scaleX(1)}
.feature-icon{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:1.25rem;background:var(--orange-lt);color:var(--orange)}
.feature-title{font-weight:700;font-size:1rem;margin-bottom:.5rem;color:var(--navy)}
.feature-desc{font-size:.84rem;color:var(--gray);line-height:1.68;margin-bottom:1rem;font-weight:300}
.feature-link{font-size:.8rem;font-weight:700;color:var(--orange);display:inline-flex;align-items:center;gap:.4rem;transition:gap .2s}
.feature-link:hover{gap:.7rem}
/* Stats strip */
.stats-strip{background:var(--navy);padding:3.5rem 2.5rem}
.stats-strip-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;text-align:center}
.s-strip-num{font-family:var(--serif);font-size:2.6rem;font-weight:700;color:var(--orange);line-height:1}
.s-strip-label{font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-top:.3rem}
/* Testimonials */
.testi-strip{background:var(--light);padding:4.5rem 2.5rem}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;max-width:1200px;margin:0 auto}
.testi-card{background:#fff;border:1px solid var(--border);border-radius:var(--r-lg);padding:1.75rem;transition:box-shadow .25s}
.testi-card:hover{box-shadow:var(--shadow-md)}
.testi-stars{color:var(--orange);font-size:.8rem;letter-spacing:.08em;margin-bottom:1rem}
.testi-quote{font-family:var(--serif);font-size:1rem;line-height:1.7;color:var(--gray2);font-style:italic;font-weight:400;margin-bottom:1.5rem}
.testi-author{display:flex;align-items:center;gap:.75rem}
.testi-ava{width:38px;height:38px;border-radius:50%;overflow:hidden;flex-shrink:0}
.testi-ava img{width:100%;height:100%}
.testi-name{font-weight:600;font-size:.85rem;color:var(--navy)}
.testi-role{font-size:.72rem;color:var(--gray)}
/* CTA */
.cta-section{padding:5rem 2.5rem;background:var(--navy);position:relative;overflow:hidden}
.cta-section::before{content:'';position:absolute;top:-100px;right:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(245,130,32,.12),transparent 70%)}
.cta-inner{max-width:700px;margin:0 auto;text-align:center;position:relative;z-index:1}
.cta-title{font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#fff;margin-bottom:1rem;line-height:1.1}
.cta-title em{color:var(--orange);font-style:italic;font-weight:400}
.cta-sub{color:rgba(255,255,255,.6);font-size:.95rem;margin-bottom:2rem;font-weight:300}
.cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
/* Footer */
.footer{background:#0a1e3a;padding:3.5rem 2.5rem 2rem}
.footer-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem}
.footer-brand-row{display:flex;align-items:center;gap:10px;margin-bottom:.9rem}
.footer-logo{background:var(--orange);border-radius:8px;padding:.3rem .7rem;font-weight:800;font-size:.85rem;color:#fff}
.footer-brand-name{font-weight:700;color:#fff;font-size:.9rem}
.footer-desc{font-size:.82rem;color:rgba(255,255,255,.4);line-height:1.75;max-width:260px;font-weight:300;margin-bottom:1.25rem}
.footer-socials{display:flex;gap:.6rem}
.social-icon{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);display:flex;align-items:center;justify-content:center;font-size:.78rem;transition:all .2s;cursor:pointer}
.social-icon:hover{background:var(--orange);color:#fff;border-color:var(--orange)}
.footer-col-h{font-weight:700;font-size:.8rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:1rem}
.footer-links{display:flex;flex-direction:column;gap:.55rem}
.footer-links li{font-size:.82rem;color:rgba(255,255,255,.5);cursor:pointer;transition:color .2s;font-weight:300}
.footer-links li:hover{color:#fff}
.footer-bottom{max-width:1200px;margin:2rem auto 0;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,.07);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.footer-copy{font-size:.75rem;color:rgba(255,255,255,.3)}
.footer-copy strong{color:var(--orange)}



/* housing grid */
.housing-section{padding:2.5rem 2rem 4rem}
.housing-section-inner{max-width:1100px;margin:0 auto}
.housing-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.75rem}
.listing-card{background:rgba(255,255,255,.06);border:1px solid var(--border-lt);border-radius:var(--r-lg);overflow:hidden;transition:transform .25s,border-color .25s,box-shadow .25s;cursor:pointer}

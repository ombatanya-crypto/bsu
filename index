            <div class="mentor-avail-row">
              <div class="avail-dot ${m.avail==='available'?'avail-green':m.avail==='busy'?'avail-yellow':'avail-gray'}"></div>
              <span style="font-size:.74rem;color:rgba(255,255,255,.5)">${m.avail==='available'?'Available now':m.avail==='busy'?'Currently in a session':'Away'}</span>
            </div>
            <div class="mentor-actions">
              <button class="btn-connect ${state.myMentors.includes(m.id)?'connected':''}" onclick="connectMentor(${m.id})">
                ${state.myMentors.includes(m.id)?'<i class="fas fa-check"></i>Connected':'<i class="fas fa-user-plus"></i>Connect'}
              </button>
              <button class="btn-msg-mentor" onclick="goTo('messages');setTimeout(()=>selectContact('${m.name.replace(/'/g,"\\'")}'),100)">
                <i class="fas fa-comment-dots"></i>Message
              </button>
            </div>
          </div>`).join('')}
      </div>
    </div>
  </div>`;
}

function connectMentor(id) {
  if(!state.user) { toast('Please sign in to connect with mentors', 'error'); goTo('auth'); return; }
  const idx = state.myMentors.indexOf(id);
  if(idx===-1) {
    state.myMentors.push(id);
    const m = MENTORS.find(x=>x.id===id);
    if(m && !state.contacts[m.name].messages.length) {
      state.contacts[m.name].messages.push({sent:false, text:`Hi ${state.user.name.split(' ')[0]}! I just accepted your connection request. I'm excited to support your journey at BSU. What's your main focus this semester?`, time:'Just now'});
    }
    toast('Connection request sent! 🎓', 'success');
  } else {
    state.myMentors.splice(idx,1);
    toast('Disconnected from mentor', 'info');
  }
  render();
}


function renderResources() {
  const tab = state.resTab;
  const filtered = RESOURCES.filter(r => tab==='all' || r.cat===tab);
  return `
  ${renderNav()}
  <div class="light-page">
    <div style="background:var(--navy);padding:3.5rem 2.5rem 2.5rem">
      <div style="max-width:1100px;margin:0 auto">
        <div class="section-overline" style="color:var(--orange)">Resource Library</div>
        <h1 style="font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#fff;margin-bottom:.75rem">Everything You Need<br>to <em style="color:var(--orange);font-style:italic;font-weight:400">Thrive at BSU</em></h1>
        <p style="font-size:.92rem;color:rgba(255,255,255,.55);font-weight:300;max-width:460px">Curated guides on immigration, banking, campus life, and more — built specifically for BSU's international students.</p>
      </div>
    </div>
    <div class="res-content">
      <div class="res-tabs">
        ${[['all','All Resources'],['immigration','🛂 Immigration'],['financial','💰 Financial'],['campus','🏫 Campus Life']].map(([v,l])=>`<button class="res-tab ${tab===v?'active':''}" onclick="state.resTab='${v}';render()">${l}</button>`).join('')}
      </div>
      <div class="res-grid">
        ${filtered.map(r=>`
          <div class="res-card">
            <div class="res-card-icon">${r.icon}</div>
            <h3>${r.title}</h3>
            <p>${r.desc}</p>
            <div class="res-card-footer">
              <span class="res-tag">${r.tag}</span>
              <button class="btn btn-primary btn-sm" onclick="toast('Opening: ${r.title}','info')">View <i class="fas fa-arrow-right" style="font-size:.7rem"></i></button>
            </div>
          </div>`).join('')}
      </div>
    </div>
  </div>`;
}


function renderFaq() {
  setTimeout(buildFaqList, 10);
  return `
  <div class="dark-page">
    ${renderNav()}
    <div class="faq-content">
      <div style="margin-bottom:2rem">
        <div class="section-overline" style="color:var(--orange)">FAQ Center</div>
        <h1 style="font-family:var(--serif);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:700;margin-bottom:.6rem">Common Questions,<br><em style="color:var(--orange);font-style:italic;font-weight:400">Answered Clearly</em></h1>
        <p style="font-size:.9rem;color:rgba(255,255,255,.5);font-weight:300">From visa rules to lease tips — the questions every international student asks, answered.</p>
      </div>
      <div class="faq-search-wrap">
        <i class="fas fa-search"></i>
        <input id="faqSearch" class="faq-search-input" placeholder="Search questions..." value="${state.faqSearch}" oninput="state.faqSearch=this.value;buildFaqList()"/>
      </div>
      <div class="faq-cats">
        ${[['all','All'],['visa','🛂 Visa'],['housing','🏠 Housing'],['financial','💰 Financial'],['campus','🏫 Campus']].map(([v,l])=>`<div class="faq-cat ${state.faqCat===v?'active':''}" onclick="state.faqCat='${v}';state.faqOpenIdx=null;buildFaqList()">${l}</div>`).join('')}
      </div>
      <div id="faqList"></div>
    </div>
  </div>`;
}
function buildFaqList() {
  const el = document.getElementById('faqList');
  if(!el) return;
  const q = state.faqSearch.toLowerCase();
  const filtered = FAQS.filter(f => (state.faqCat==='all'||f.cat===state.faqCat) && (!q||f.q.toLowerCase().includes(q)||f.a.toLowerCase().includes(q)));
  el.innerHTML = filtered.map((f,i)=>`
    <div class="faq-item">
      <div class="faq-q" onclick="state.faqOpenIdx=state.faqOpenIdx===i?null:i;buildFaqList()">
        <span>${f.q}</span>
        <i class="fas fa-chevron-down faq-chevron ${state.faqOpenIdx===i?'open':''}"></i>
      </div>
      <div class="faq-answer ${state.faqOpenIdx===i?'open':''}">${f.a}</div>
    </div>`).join('') || `<div style="padding:2rem;text-align:center;color:rgba(255,255,255,.3);font-size:.88rem">Nothing matched. Try asking Maya directly — she knows every corner of BSU.</div>`;
}


function render() {
  const pages = {
    home: renderHome,
    auth: renderAuth,
    dashboard: renderDashboard,
    housing: renderHousing,
    messages: renderMessages,
    chatbot: renderChatbot,
    mentorship: renderMentorship,
    resources: renderResources,
    faq: renderFaq,
  };
  document.getElementById('app').innerHTML = (pages[state.page] || renderHome)();
  // Post-render hooks
  if(state.page === 'housing') setTimeout(buildHousingCards, 10);
  if(state.page === 'chatbot') setTimeout(initChatbot, 10);
  if(state.page === 'faq') setTimeout(buildFaqList, 10);
  if(state.page === 'messages') setTimeout(()=>{ const el=document.getElementById('chatMsgs');if(el)el.scrollTop=el.scrollHeight; },50);
  if(state.page === 'home') setTimeout(animateCounters, 200);
}


function animateCounters() {
  function count(id, target, suffix='') {
    const el = document.getElementById(id);
    if(!el) return;
    let cur=0; const step=Math.ceil(target/55);
    const t = setInterval(()=>{cur=Math.min(cur+step,target);el.textContent=cur+suffix;if(cur>=target)clearInterval(t);},25);
  }
  count('hs1',300,'+'); count('hs2',HOUSINGS.length,''); count('hs3',MENTORS.length,'');
}

/* INIT */
render();
</script>
</body>
</html>

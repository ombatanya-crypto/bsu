function buildHousingCards() {
  const grid = document.getElementById('housingGrid');
  const nr = document.getElementById('hNoResults');
  if(!grid) return;
  const all = [...HOUSINGS, ...getAllStudentListings()];
  let filtered = all.filter(h => {
    const q = state.hSearch.toLowerCase();
    if(q && !h.title.toLowerCase().includes(q) && !h.location.toLowerCase().includes(q)) return false;
    if(state.hType !== 'all' && h.type !== state.hType) return false;
    if(state.hAvail && state.hAvail !== 'all' && h.availability !== state.hAvail) return false;
    if(state.hBeds) {
      const b = parseInt(state.hBeds);
      if(state.hBeds==='3' ? h.beds < 3 : h.beds !== b) return false;
    }
    if(state.hPriceFilter) {
      const max = parseInt(state.hPriceFilter);
      if(state.hPriceFilter==='9999' ? h.price < 1600 : h.price > max) return false;
    }
    return true;
  });
  const countEl = document.getElementById('hCount');
  if(countEl) countEl.textContent = filtered.length;
  if(!filtered.length) { grid.innerHTML=''; nr.style.display='block'; return; }
  nr.style.display='none';
  grid.innerHTML = filtered.map(h => `
    <div class="listing-card" onclick="openListingModal(${h.id})">
      <div class="listing-img">
        <img src="${h.img}" alt="${h.title}" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1560184897-ae75f418493e?w=700&h=420&fit=crop'"/>
        <div class="listing-img-overlay"></div>
        <div class="listing-badges">
          <span class="badge badge-type">${h.type}</span>
          <span class="badge badge-${h.availability.toLowerCase()}">${h.availability}</span>
        </div>
        <button class="listing-save-btn ${state.favorites.includes(h.id)?'saved':''}" onclick="event.stopPropagation();toggleFav(${h.id},this)" title="Save listing">
          <i class="fa${state.favorites.includes(h.id)?'s':'r'} fa-heart"></i>
        </button>
        <div class="listing-price-bar">
          <div class="listing-price">$${h.price.toLocaleString()}<sub>/mo</sub></div>
          <div style="font-size:.72rem;color:rgba(255,255,255,.55)">${h.distance}</div>
        </div>
      </div>
      <div class="listing-body">
        <div class="listing-title">${h.title}</div>
        <div class="listing-location"><i class="fas fa-location-dot"></i>${h.location}</div>
        <div class="listing-specs">
          <div class="l-spec"><i class="fas fa-bed"></i>${h.beds} Bed${h.beds>1?'s':''}</div>
          <div class="l-spec"><i class="fas fa-bath"></i>${h.baths} Bath${h.baths>1?'s':''}</div>
          <div class="l-spec"><i class="fas fa-ruler-combined"></i>${h.sqft} sqft</div>
        </div>
        <div class="listing-tags">${(h.tags||[]).slice(0,3).map(t=>`<span class="listing-tag">${t}</span>`).join('')}</div>
        <div class="listing-footer">
          <button class="btn-view-detail" onclick="event.stopPropagation();openListingModal(${h.id})"><i class="fas fa-eye"></i>View Details</button>
          <button class="btn-save-listing ${state.favorites.includes(h.id)?'saved':''}" onclick="event.stopPropagation();toggleFav(${h.id},this)" title="Save">
            <i class="fa${state.favorites.includes(h.id)?'s':'r'} fa-heart"></i>
          </button>
        </div>
      </div>
    </div>`).join('');
}

function toggleFav(id, btn) {
  if(!state.user) { toast('Please sign in to save listings', 'error'); return; }
  const idx = state.favorites.indexOf(id);

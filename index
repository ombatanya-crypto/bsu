.btn-save-listing{padding:.55rem .85rem;background:rgba(255,255,255,.07);border:1px solid var(--border-lt);border-radius:var(--r-sm);color:rgba(255,255,255,.6);font-size:.8rem;cursor:pointer;transition:all .2s}

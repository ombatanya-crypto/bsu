.listing-price-bar{position:absolute;bottom:.9rem;left:.9rem;right:.9rem;display:flex;align-items:flex-end;justify-content:space-between}
.listing-price{font-family:var(--serif);font-size:1.3rem;font-weight:700;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.5)}
